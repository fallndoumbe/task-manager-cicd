includes:
    - vendor/nunomaduro/larastan/extension.neon

parameters:
    level: 5

    paths:
        - app
        - config
        - database
        - routes
        - tests

    excludePaths:
        - vendor
        - storage
        - bootstrap/cache

    checkMissingIterableValueType: false
    checkGenericClassInNonGenericObjectType: false

    ignoreErrors:
        - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Builder#'
